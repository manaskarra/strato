# ============================================
# STRATO - Environment Variables Template
# ============================================
# SECURITY: Never commit actual API keys to version control
# Copy this file to .env.local and add your real values

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:9320

# EODHD Market Data API
# Get your API key from: https://eodhd.com/
EODHD_API_KEY=your_eodhd_api_key_here

# LLM/Alto AI Configuration
LLM_BASE_URL=https://litellmprod.deriv.ai/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4.1-mini

# Alto AI (Alternative naming for consistency)
ALTO_API_BASE_URL=https://litellmprod.deriv.ai/v1
ALTO_API_KEY=your_alto_api_key_here
ALTO_MODEL=gpt-4.1-mini

# ============================================
# IMPORTANT SECURITY NOTES:
# ============================================
# 1. NEVER commit .env.local to git
# 2. Rotate API keys regularly
# 3. Use different keys for dev/staging/production
# 4. Monitor API usage for anomalies
# 5. Set up rate limiting alerts
# ============================================
